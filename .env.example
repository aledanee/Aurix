# Aurix — Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# NEVER commit .env to version control

# PostgreSQL
POSTGRES_USER=aurix
POSTGRES_PASSWORD=aurix_dev_password
POSTGRES_DB=aurix

# Backend
DATABASE_URL=postgres://aurix:aurix_dev_password@postgres:5432/aurix
REDIS_URL=redis://redis:6379
JWT_SECRET=dev-secret-key-change-in-production-minimum-32-bytes
PORT=8080
GOLD_PRICE_EUR=65.00
SEED_BALANCE_EUR_CENTS=1000000

# Frontend
REACT_APP_API_URL=http://localhost:8080
